TELEGRAM_BOT_TOKEN=your_bot_token
GEMINI_API_KEY=your_gemini_key
ADMIN_CHAT_ID=your_chat_id
# Time for daily penalty (00:00)
PENALTY_HOUR=0
PENALTY_MINUTE=0
